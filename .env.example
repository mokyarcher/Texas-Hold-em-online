# 德州扑克游戏环境变量配置

# 服务器配置
PORT=3000
NODE_ENV=production

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=poker-secret-key-change-in-production-please-use-random-string

# 数据库配置
DB_PATH=./backend/db/poker.db

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/poker.log

# CORS 配置（生产环境请设置具体的域名）
CORS_ORIGIN=*

# 会话配置
SESSION_SECRET=your-session-secret-change-in-production

# 管理员用户名
ADMIN_USERNAME=mokyarcher
